# OpenAI API Key (STT + TTS; obbligatoria anche con LLM_PROVIDER=gemini)
OPENAI_API_KEY=sk-your-api-key-here

# LLM risposte: openai (default) | gemini
# LLM_PROVIDER=openai
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# Latenza voce (botta e risposta): risposte corte + TTS senza loudnorm
# LLM_VOICE_MAX_TOKENS=220
# TTS_SKIP_LOUDNORM=1
# TTS_SPEED=1.05
# STT_MODEL=gpt-4o-mini-transcribe
# WAKE_STT_MODEL=gpt-4o-mini-transcribe

# STT: default OpenAI Whisper (stessa OPENAI_API_KEY). Groq/Deepgram solo con STT_PROVIDER esplicito + chiave.
# STT_PROVIDER=whisper
# GROQ_API_KEY=  # inutile finché STT_PROVIDER non è "groq"
GROQ_API_KEY=

# Prompt STT (Whisper/Groq): vocaboli/frasi che aiutano il riconoscimento (es. prova prova prova)
# WHISPER_PROMPT=Trascrizione fedele in italiano. NON tradurre in inglese. NON inventare sottotitoli.

# Endpointing ascolto continuo (ms): pausa prima di inviare il comando a STT
# STT_CMD_SILENCE_MS=2800
# STT_CMD_SLICE_MS=20000
# STT_WAKE_SLICE_MS=6000
# STT_CMD_MIN_VOICE_MS=400
# STT_LISTEN_SILENCE_SEC=2.8

# STT fuzzy: config/stt_config.json. Vocabolario: config/italian_vocabulary.txt

# Profilo ospiti in visita (config/visitor_profiles.json). Es. visita Granzotto:
# G1_VISITOR_PROFILE=granzotto
# Per disattivare dopo la visita: commenta o rimuovi la riga e riavvia il server.

# Gesto braccia durante TTS (default face_wave). off = disattiva. Es. face_wave,right_hand_up
# G1_SPEAK_GESTURE=face_wave

# Robot G1: IP corpo (sport mode / subnet 192.168.123.x). config/robot_actions.json
# UNITREE_ROBOT_IP=192.168.123.161
# Interfaccia CycloneDDS: auto = rileva l'interfaccia con IP 192.168.123.x; oppure forza eth0/usb0/usb1
# UNITREE_DDS_INTERFACE=auto

# Camera dashboard + YOLO (stream MJPEG su /dashboard → Avvia stream)
# G1_CAMERA_SOURCE=v4l          # v4l (default) | realsense
# G1_CAMERA_DEVICE=0
# G1_CAMERA_SOURCE=realsense    # camera integrata G1 (RealSense)
# G1_YOLO_BACKEND=onnx          # onnx (default, leggero) | ultralytics (pesante, non su Jetson)
# G1_YOLO_MODEL=yolov8n.onnx    # scaricato auto in config/models/ al primo avvio
# G1_CAMERA_YOLO=1
# G1_CAMERA_DEPTH=1              # depth RealSense sui box YOLO (solo con G1_CAMERA_SOURCE=realsense)
# G1_YOLO_CONF=0.35
# G1_YOLO_CLASSES=person,dining table,chair   # vuoto = tutte le classi COCO

# Auto-pick (Fase 3): YOLO+depth → replay teaching slot (default) o manovra safe_reach
# G1_PICK_MODE=teaching             # teaching | safe_reach
# G1_PICK_ENABLED=0
# G1_PICK_CLASS=bottle
# G1_PICK_DEPTH_MIN=0.35
# G1_PICK_DEPTH_MAX=0.75
# G1_PICK_TEACHING_SLOT=0
# G1_PICK_COOLDOWN_SEC=20
# G1_PICK_STABLE_FRAMES=4
# G1_PICK_WAIST_GAIN=0.55
# G1_PICK_YAW_GAIN=0.85
# G1_PICK_PITCH_GAIN=0.40
# G1_PICK_TWO_HANDS=1
# G1_PICK_GRASP=1
# G1_PICK_GRASP_HOLD_SEC=0.8
# G1_PICK_GRASP_OPEN_ON_RETURN=1
# G1_PICK_FREEZE_LEFT_ARM=0
# G1_HAND_TYPE=auto

# Soundboard: slot totali (default 20). Aumenta per nuovi audio senza cancellare i primi (es. 30).
# G1_SOUNDBOARD_SLOTS=100

# URL pubblico per redirect HTTP→HTTPS (scripts/http_redirect.py). Sul Jetson usa l'IP della scheda (es. 192.168.123.164).
# TALK_PUBLIC_HOST=192.168.123.164
# TALK_HTTPS_PORT=8081
# TALK_HTTP_REDIRECT_PORT=8080

# Lingua preferita per TTS (it, en, es, etc.)
TTS_LANGUAGE=it

# Modello LLM: gpt-4o-mini (veloce) | gpt-4o | gpt-4-turbo
LLM_MODEL=gpt-4o-mini

# Token massimi per la risposta LLM (default 1024). Modelli con reasoning usano almeno 512.
# LLM_MAX_COMPLETION_TOKENS=1024

# Voce TTS OpenAI maschile consigliata per italiano: onyx, echo, fable (femminile: nova, shimmer, alloy)
TTS_VOICE=onyx

# ID microfono (numero, oppure lascia vuoto per default)
# Lista con: python -m talk_module.cli list-devices
MICROPHONE_DEVICE_ID=

# Sample rate registrazione (Hz)
SAMPLE_RATE=16000

# Timeout recording (secondi) - massimo attesa comando vocale
RECORDING_TIMEOUT=10

# Wake word globale (legacy): se true, anche senza skip_wake dal client serve «Hey G1».
# Default: false — push-to-talk risponde sempre; «Hey G1» solo in ascolto continuo (skip_wake:false).
# WAKE_WORD_REQUIRED=true
