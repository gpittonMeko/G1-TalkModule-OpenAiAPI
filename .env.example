# OpenAI API Key (obbligatorio per LLM e TTS)
OPENAI_API_KEY=sk-your-api-key-here

# STT: default OpenAI Whisper (stessa OPENAI_API_KEY). Groq/Deepgram solo con STT_PROVIDER esplicito + chiave.
# STT_PROVIDER=whisper
# GROQ_API_KEY=  # inutile finché STT_PROVIDER non è "groq"
GROQ_API_KEY=

# Prompt STT (Whisper/Groq): vocaboli/frasi che aiutano il riconoscimento (es. prova prova prova)
# WHISPER_PROMPT=Lingua italiana. Esempi: prova prova prova, che ore sono. Trascrivi solo le parole pronunciate.

# STT fuzzy: config/stt_config.json. Vocabolario: config/italian_vocabulary.txt

# Robot G1: IP corpo (sport mode / subnet 192.168.123.x). config/robot_actions.json
# UNITREE_ROBOT_IP=192.168.123.161
# Braccio sinistro guasto: true = nessun comando al braccio SX (default true in campo)
# DISABLE_LEFT_ARM=true
# Interfaccia CycloneDDS: auto = rileva l'interfaccia con IP 192.168.123.x; oppure forza eth0/usb0/usb1
# UNITREE_DDS_INTERFACE=auto

# URL pubblico per redirect HTTP→HTTPS (scripts/http_redirect.py). Sul Jetson usa l'IP della scheda (es. 192.168.123.164).
# TALK_PUBLIC_HOST=192.168.123.164
# TALK_HTTPS_PORT=8081
# TALK_HTTP_REDIRECT_PORT=8080

# Lingua preferita per TTS (it, en, es, etc.)
TTS_LANGUAGE=it

# Modello LLM: gpt-4o-mini (veloce) | gpt-4o | gpt-4-turbo
LLM_MODEL=gpt-4o-mini

# Token massimi per la risposta LLM (default 1024). Modelli con reasoning usano almeno 512.
# LLM_MAX_COMPLETION_TOKENS=1024

# Voce TTS OpenAI (alloy, echo, fable, onyx, nova, shimmer)
TTS_VOICE=shimmer

# ID microfono (numero, oppure lascia vuoto per default)
# Lista con: python -m talk_module.cli list-devices
MICROPHONE_DEVICE_ID=

# Sample rate registrazione (Hz)
SAMPLE_RATE=16000

# Timeout recording (secondi) - massimo attesa comando vocale
RECORDING_TIMEOUT=10

# Wake word globale (legacy): se true, anche senza skip_wake dal client serve «Hey G1».
# Default: false — push-to-talk risponde sempre; «Hey G1» solo in ascolto continuo (skip_wake:false).
# WAKE_WORD_REQUIRED=true
